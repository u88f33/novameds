                <td>Rs 900</td>
            </tr>
        </tbody>
    </table>

    </div>

    <%# Recent Customers Table %>
    <div class="dashboard__table-container">

        <h3 class="dashboard__section-title">Recent Customers</h3>

        <table class="dashboard__table">
            <thead>
                <tr>
                    <th style="width: 5%;">#</th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th>Join Date</th>
                </tr>
            </thead>

            <tbody>
                <tr>
                    <td>1</td>
