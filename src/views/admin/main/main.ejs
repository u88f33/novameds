<%- include( "../../partials/admin/sidebar" ) -%>

<div class="dashboard">

    <header class="dashboard__header">

        <nav class="dashboard__nav">
            <div class="dashboard__nav-title">
                <h1>Dashboard</h1>
            </div>

            <a href="/admin" class="dashboard__profile">

                <div class="dashboard__profile-image-wrapper">
                    <img src="/assets/images/admin.png" class="dashboard__profile-image" />
                </div>

                <div class="dashboard__profile-text">
                    Admin
                </div>

            </a>
        </nav> 
        
    </header>

    <%# Dashboard Statistics %>
    <div class="dashboard__stats-container">
        <h3 class="dashboard__section-title">Statistics</h3>
        
        <div class="dashboard__stats">


        <!-- Medicines -->
        <div class="dashboard__stat-card">
            <div class="dashboard__stat-icon">
                <i class="fa-solid fa-capsules"></i>
            </div>
            <div class="dashboard__stat-content">
                <h2 class="dashboard__stat-number">120</h2>
                <p class="dashboard__stat-label">Total Medicines</p>
            </div>
        </div>

        <!-- Orders -->
        <div class="dashboard__stat-card">
            <div class="dashboard__stat-icon">
                <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <div class="dashboard__stat-content">
                <h2 class="dashboard__stat-number">45</h2>
                <p class="dashboard__stat-label">Pending Orders</p>
            </div>
        </div>

        <!-- Customers -->
        <div class="dashboard__stat-card">
            <div class="dashboard__stat-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <div class="dashboard__stat-content">
                <h2 class="dashboard__stat-number">300</h2>
                <p class="dashboard__stat-label">Total Customers</p>
            </div>
        </div>

        <!-- Suppliers -->
        <div class="dashboard__stat-card">
            <div class="dashboard__stat-icon">
                <i class="fa-solid fa-truck"></i>
            </div>
            <div class="dashboard__stat-content">
                <h2 class="dashboard__stat-number">25</h2>
                <p class="dashboard__stat-label">Total Suppliers</p>
            </div>
        </div>

        </div>
    </div>

    <%# Recent Orders Table %>
