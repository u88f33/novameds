        </table>
    </div>

    <%# Dashboard Analytics %>
    <div class="dashboard__analytics">

        <!-- Map (Left) -->
        <div class="dashboard__map-container">
            <h3 class="dashboard__section-title">Customer Locations</h3>
            <div id="map"></div>
        </div>

        <!-- Bar Chart (Right) -->
        <div class="dashboard__chart-container">
            <h3 class="dashboard__section-title">Monthly Orders</h3>
            <canvas id="ordersChart"></canvas>
        </div>

    </div>

</div>

