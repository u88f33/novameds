<%- include( "../../../partials/admin/sidebar" ) -%>

<div class="dashboard">
    <header class="dashboard__header">

        <nav class="dashboard__nav">
            <div class="dashboard__nav-title">
                <h1>Dashboard</h1>
            </div>

            <a href="/admin" class="dashboard__profile">

                <div class="dashboard__profile-image-wrapper">
                    <img src="/assets/images/admin.png" class="dashboard__profile-image" />
                </div>

                <div class="dashboard__profile-text">
                    Admin
                </div>

            </a>
        </nav> 
        
    </header>

    <div class="dashboard__section">

        <div class="dashboard__section-main">
            <h3 class="dashboard__section-title">Update Medicine Record</h3>

            <div class="dashboard__secion-form-container">
                <form 
                    action="/admin/manage/medicines/update/medicine_id_123"
                    method="POST"
                    class="dashboard__secion-form">

                <!-- First Row -->
                <div class="dashboard__secion-form-row">
                    
                    <!-- Medicine Name -->
                    <div class="dashboard__secion-form-group">
                        <label for="medicineName" class="dashboard__secion-form-label">
                            Medicine Name
                        </label>
                        <input 
                            type="text" 
                            id="medicineName" 
                            name="medicine_name" 
                            class="dashboard__secion-form-input"
                            value="Updated Medicine Name"
                        />
                    </div>

                    <!-- Medicine Category -->
                    <div class="dashboard__secion-form-group">
                        <label for="medicineCategory" class="dashboard__secion-form-label">Medicine Category</label>
                        <input 
                            type="text" 
                            id="medicineCategory" 
                            name="medicine_category" 
                            class="dashboard__secion-form-input"
                            value="Updated Medicine Category"
                        />
                    </div>

                </div>

                <!-- Second Row -->
                <div class="dashboard__secion-form-row">
                    
                    <!-- Medicine Price -->
                    <div class="dashboard__secion-form-group">
                        <label for="medicinePrice" class="dashboard__secion-form-label">Medicine Price</label>
                        <input 
                            type="text" 
                            id="medicinePrice" 
                            name="medicine_price" 
                            class="dashboard__secion-form-input"
                            value="Updated Medicine Price"
                        />
                    </div>

                    <!-- Stock Quantity -->
                    <div class="dashboard__secion-form-group">
                        <label for="stockQuantity" class="dashboard__secion-form-label">Stock Quantity</label>
                        <input 
                            type="text" 
                            id="stockQuantity" 
                            name="medicine_stock" 
                            class="dashboard__secion-form-input"
                            value="Updated Stock Quantity"
                        />
                    </div>

                </div>

                <!-- Third Row -->
                <div class="dashboard__secion-form-row">
                    
                    <!-- Supplier Name -->
                    <div class="dashboard__secion-form-group">
                        <label for="supplierName" class="dashboard__secion-form-label">Supplier Name</label>
                        <select 
                            id="supplierName" 
                            name="supplier_name" 
                            class="dashboard__secion-form-select"
                        >
                            <option value="abc_pharma">ABC Pharma</option>
                            <option value="xyz_suppliers">XYZ Suppliers</option>
                            <option value="healthcorp">HealthCorp</option>
                            <option value="medisupply">MediSupply</option>
                        </select>
                    </div>

                    <!-- Upload Medicine Image -->
                    <div class="dashboard__secion-form-group">
                        <label for="medicineImage" class="dashboard__secion-form-label">Upload Medicine Image</label>
                        <input 
                            type="file" 
                            id="medicineImage" 
                            name="medicine_image" 
                            class="dashboard__secion-form-file"
                        />
                    </div>

                </div>

                <div class="dashboard__secion-form-actions">
                    <button type="submit" class="dashboard__secion-form-button">
                        Update Record
                    </button>
                    <a href="/admin/manage/medicines" class="dashboard__secion-action-button">
                        Go Back
                    </a>
                </div>

                </form>
            </div>
        </div>

    </div>
</div>

<%- include( "../../../partials/admin/footer" ) -%>