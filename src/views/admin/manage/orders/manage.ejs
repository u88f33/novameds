<%- include( "../../../partials/admin/sidebar" ) -%>

<div class="dashboard">
    <header class="dashboard__header">

        <nav class="dashboard__nav">
            <div class="dashboard__nav-title">
                <h1>Dashboard</h1>
            </div>

            <a href="/admin" class="dashboard__profile">

                <div class="dashboard__profile-image-wrapper">
                    <img src="/assets/images/admin.png" class="dashboard__profile-image" />
                </div>

                <div class="dashboard__profile-text">
                    Admin
                </div>

            </a>
        </nav> 
        
    </header>

    <div class="dashboard__section">

        <!-- Top Section -->
        <div class="dashboard__section-top">
            <h3 class="dashboard__section-title">Order Details</h3>

            <div class="dashboard__section-actions">
                <input 
                    type="text"
                    style="width: 100% !important;"
                    class="dashboard__section-search" 
                    placeholder="Search Specific Order"
                    oninput="searchOrder( this.value )"
                />
            </div>
        </div>

        <!-- Table -->
        <table class="dashboard__section-table">
            <thead>
                <tr>
                    <th>No.</th>
                    <th>Customer Name</th>
                    <th>Address</th>
                    <th>Total Amount</th>
                    <th>Order Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody id="orderTableBody">
                <% customersOrders.forEach(( singleOrder, index ) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= singleOrder.customerId.customerName %></td>
                        <td>
                            <%= `${singleOrder.shippingAddress.address}, ${singleOrder.shippingAddress.city}, ${ singleOrder.shippingAddress.country }` %>
                        </td>
                        <td><%= singleOrder.totalAmount %></td>
                        <td>
                            <%
                                const date = new Date();
                                const months = [ 
                                                "January", "February", "March", 
                                                "April", "May", "June",
                                                "July", "August", "September",
                                                "October", "November", "December" 
                                            ];
                            %>
                            <%= `${months[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}` %>
                        </td>
                            <%
                                let bgColor = "";

                                switch ( singleOrder.orderStatus ) {
                                    case "Pending": {
                                        bgColor = "bg-danger";
                                        break;
                                    }
                                    case "Delivered": {
                                        bgColor = "bg-success";
                                        break;
                                    }
                                    case "Cancelled": {
                                        bgColor = "bg-warning";
                                    }
                                }
                            %>
                        <td class="text-light <%= bgColor %>">
                            <%= singleOrder.orderStatus %>
                        </td>
                        <td>
                            <div class="dashboard__section-cell-actions">
                                <a href="/admin/manage/orders/view/<%= singleOrder._id %>" class="action-btn">
                                    View or Manage
                                </a>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <!-- Pagination -->
        <div class="dashboard__section-pagination">

            <% if ( hasPrevPage ) { %>
                <a href="/admin/manage/orders/?page=<%= prevPage %>" class="pagination__btn">&laquo;</a>
            <% } %>

            <div class="pagination__numbers">
                <% if ( customersOrders ) { %>

                    <% if ( prevPage ) { %>
                        <a href="/admin/manage/orders/?page=<%= prevPage %>" class="pagination__btn">
                            <%= prevPage %>
                        </a>
                    <% } %>

                    <% if ( currentPage ) { %>
                        <a href="/admin/manage/orders/?page=<%= currentPage %>" class="pagination__btn">
                            <%= currentPage %>
                        </a>
                    <% } %>

                    <% if ( nextPage ) { %>
                        <a href="/admin/manage/orders/?page=<%= nextPage %>" class="pagination__btn">
                            <%= nextPage %>
                        </a>
                    <% } %>

                <% } %>
            </div>

            <% if ( hasNextPage ) { %>
                <a href="/admin/manage/orders/?page=<%= nextPage %>" class="pagination__btn">&raquo;</a>
            <% } %>

        </div>

    </div>
</div>

<script src="/js/scripts/orders/search_order.js"></script>
<%- include( "../../../partials/admin/footer" ) -%>