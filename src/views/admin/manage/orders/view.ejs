<%- include( "../../../partials/admin/sidebar" ) -%>

<div class="dashboard">
    <header class="dashboard__header">

        <nav class="dashboard__nav">
            <div class="dashboard__nav-title">
                <h1>Dashboard</h1>
            </div>

            <a href="/admin" class="dashboard__profile">

                <div class="dashboard__profile-image-wrapper">
                    <img src="/assets/images/admin.png" class="dashboard__profile-image" />
                </div>

                <div class="dashboard__profile-text">
                    Admin
                </div>

            </a>
        </nav> 
        
    </header>

    <div class="dashboard__section">

        <div class="dashboard__section-main">
            <h3 class="dashboard__section-title mb-0">Update Order: </h3>
            
            <div class="section-row__col-2 mt-4">
                <div class="section__col section__col-1">
                    <form class="payment-status__form" method="POST" action="/admin/manage/orders/update/payment/status/<%= customerOrder._id %>">
                        <h2>Payment Status</h2>
                        <select name="payment_status">
                            <option value="Unpaid">Unpaid</option>
                            <option value="Paid">Paid</option>
                            <option value="COD">Pay on Delivery</option>
                        </select>
                        <button type="submit">Confirm</button>
                    </form>
                </div>

                <div class=" section__col section__col-2">
                    <form class="order-status__form" method="POST" action="/admin/manage/orders/update/order/status/<%= customerOrder._id %>">
                        <h2>Order Status</h2>
                        <select name="order_status">
                            <option value="Pending">Pending</option>
                            <option value="Delivered">Delivered</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <button type="submit">Confirm</button>
                    </form>
                </div>
            </div>

            <h3 class="dashboard__section-title mb-0">Order Details: </h3>            
            <div class="mt-4">

                <table class="dashboard__section-view-table">
                    <tbody>
                        <tr>
                            <th>Customer Name</th>
                            <td><%= customerOrder.customerId.customerName %></td>
                        </tr>

                        <tr>
                            <th>Customer Email</th>
                            <td><%= customerOrder.customerId.customerEmail %></td>
                        </tr>

                        <tr>
                            <th>Customer Phone</th>
                            <td><%= customerOrder.customerId.customerPhone %></td>
                        </tr>

                        <tr>
                            <th>Customer Address</th>
                            <td>
                                <%= customerOrder.customerId.customerAddress %>,
                                <%= customerOrder.customerId.customerCity %>,                                
                                <%= customerOrder.customerId.customerCountry %>                                
                            </td>
                        </tr>

                        <tr>
                            <% 
                                let date = new Date( customerOrder.createdAt );
                                let monthNames = [
                                    "January", "Feburary", "March", "April", "May",
                                    "June", "July", "August", "September",
                                    "October", "November", "December"
                                ];
                                let dayNames = [
                                    "Sunday", "Monday", "Tuesday", "Wednesday",
                                    "Thursday", "Friday", "Saturday",
                                ]
                            %>
                            <th>Date</th>
                            <td>
                                <%= dayNames[ date.getDay() ] %>,
                                <%= monthNames[date.getMonth()] %> 
                                <%= date.getDate() %>,
                                <%= date.getFullYear() %>
                            </td>
                        </tr>
                        
                        <tr>
                            <th>Time</th>
                            <td>
                                <%= date.getHours()  %>:<%= date.getMinutes() %>
                            </td>
                        </tr>
                        <tr>
                            <th>Payment</th>
                            <td><%= customerOrder.paymentStatus %></td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td><%= customerOrder.orderStatus %></td>
                        </tr>
                        <tr>
                            <th>Total Amount</th>
                            <td>Rs. <%= customerOrder.totalAmount %></td>
                        </tr>
                    </tbody>
                </table>

            </div>

        </div>

    </div>

    <div class="dashboard__section pt-0">
        <div class="dashboard__section-main">
            <h3 class="dashboard__section-title mb-0">Ordered Medicines: </h3>

            <div class="mt-4">
                <table class="dashboard__section-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Medicine Name</th>
                            <th>Category</th>
                            <th>Single Medicine Price</th>
                            <th>quantity</th>
                            <th>Total Price</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        
                        <% customerOrder.items.forEach((singleMedicineRecord, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= singleMedicineRecord.medicineId.medicineName %></td>
                                <td><%= singleMedicineRecord.medicineId.medicineCategory %></td>
                                <td><%= singleMedicineRecord.medicineId.medicinePrice %></td>
                                <td><%= singleMedicineRecord.quantity %></td>
                                <td><%= singleMedicineRecord.price %></td>
                                <td>
                                    <div class="dashboard__section-cell-actions">
    
                                        <a href="/admin/manage/medicines/view/<%= singleMedicineRecord.medicineId._id %>" class="action-btn">
                                            <i class="fa-solid fa-eye"></i>
                                            More Info
                                        </a>
                                        
                                    </div>
                                </td>
                            </tr>                            
                        <% }); %>

                    </tbody>
                </table>
            </div>

            <div class="dashboard__secion-actions">
                <a href="/admin/manage/orders" class="dashboard__secion-action-button">
                    Go Back
                </a>
            </div>

        </div>
    </div>
</div>

<%- include( "../../../partials/admin/footer" ) -%>