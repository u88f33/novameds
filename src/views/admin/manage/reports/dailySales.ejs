<%- include( "../../../partials/admin/sidebar" ) -%>

<div class="dashboard">
    <header class="dashboard__header">

        <nav class="dashboard__nav">
            <div class="dashboard__nav-title">
                <h1>Dashboard</h1>
            </div>

            <a href="/admin" class="dashboard__profile">

                <div class="dashboard__profile-image-wrapper">
                    <img src="/assets/images/admin.png" class="dashboard__profile-image" />
                </div>

                <div class="dashboard__profile-text">
                    Admin
                </div>

            </a>
        </nav> 
        
    </header>

    <div class="dashboard__section">

        <!-- Top Section -->
        <div class="dashboard__section-top">
            <div class="d-flex justify-content-between">
                <h3 class="dashboard__section-title">Daily Sales Reports:</h3>

            </div>

            <table>
                <tr>
                    <th>No.</th>
                    <th>Reports</th>
                    <th>File</th>
                </tr>
                <% pdfSalesReportsArray.forEach((singleDailySalesReport, idx) => { %>
                    <tr>
                        <td><%= idx %></td>
                        <td>Sales Report of <%= singleDailySalesReport %></td>
                        <td>
                            <a 
                                href="/assets/reports/dailySales/<%= singleDailySalesReport %>" 
                                target="_blank">
                                <%= singleDailySalesReport %>
                            </a>
                        </td>
                    </tr>
                    <% }); %>
            </table>

        </div>

    </div>
</div>

<script src="/js/scripts/orders/search_order.js"></script>
<%- include( "../../../partials/admin/footer" ) -%>