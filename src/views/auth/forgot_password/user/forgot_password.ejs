<%- include( "../../../partials/header/prelogin" ) -%>

<div class="container">
    <div class="row">
        <div class="col-12">

            <div class="login-container">
                <div class="login-container-left">
                    
                    <h1 class="mb-4">RESET PASSWORD</h1>

                    <%# User Login Form %>
                    <form
                    class="form login-form"
                    action="/user/forgot"
                    method="POST">

                    <div class="mb-3">
                        <label for="emailInputLogin" class="form-label">Email</label>
                        <input 
                            type="email"
                            class="form-control border border-dark"
                            id="emailInputLogin"
                            placeholder="username@gmail.com"
                            required="true"
                            maxlength="60"
                            name="user_email"
                            autocomplete="off"
                        />
                    </div>

                    <button type="submit" class="btn login-btn">Send Reset Link</button>

                </form>

                <div class="mt-4">
                    <% if ( errorMessage ) { %>
                        <div class="alert-box">
                            <p class="mb-0"><b>Error</b>: <%= errorMessage %></p>
                        </div>
                    <% } %>
                </div>

            </div>

            <div
                class="login-container-right">
                <img 
                    src="/assets/images/login_page_image.jpg"
                />
            </div>
            </div>
            </div>
        </div>
    </div>
</div>



<script src="/js/scripts/home/prelogin/search_medicine.js"></script>
<%- include( "../../../partials/footer/footer" ) -%>