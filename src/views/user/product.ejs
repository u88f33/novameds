<%- include( "../partials/header/postlogin" ) -%>

<div class="container">
    <div class="row">

        <div class="product">
            <div class="product__container">

                <div class="product__image-container">
                    <img src="/assets/images/no-image.jpg" alt="Medicine" class="product__image">
                </div>

                <div class="product__details">
                    <h1 class="product__title">Paracetamol Tablets</h1>
                    <h3 class="product__price">Rs. 180</h3>

                    <div class="product__quantity">
                        <button class="product__btn product__btn--minus">-</button>
                        <input type="text" value="1" class="product__input" readonly>
                        <button class="product__btn product__btn--plus">+</button>
                    </div>

                    <button class="product__cart-btn">Add to Cart</button>
                </div>

            </div>
        </div>

    <script src="/js/scripts/product.js"></script>

    </div>
</div>



<%- include( "../partials/footer/footer" ) -%>