<%- include( "../partials/header/postlogin" ) -%>

<div class="container">
    <div class="row">

        <div class="shopping-cart">
            <div class="shopping-cart__heading-container">
                <h1 class="shopping-cart__heading">Shopping Cart</h1>
            </div>

            <div class="shopping-cart__body-container">
                <div class="shopping-cart__items-list">
                    <table class="shopping-cart__list-table">
                        <thead>
                            <tr>
                                <th class="shopping-cart__product-col">Product</th>
                                <th class="shopping-cart__price-col">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cartRecords.forEach(singleCartItem => { %>
                                <tr>
                                    <td>
                                        <div class="shopping-cart__product-details-container">
                                            <div class="shopping-cart__product-image-container">
                                                <img 
                                                    src="/uploads/medicines/<%= singleCartItem.medicineId.medicineImage %>" 
                                                    alt="Product Image"
                                                    class="shopping-cart__product-image"
                                                />
                                            </div>
                                            <div class="shopping-cart__product-body">
                                                <h3 class="shopping-cart__product-details-title"><%= singleCartItem.medicineId.medicineName %></h3>
                                                <h3 class="shopping-cart__product-details-subtitle mb-4"><%= singleCartItem.medicineId.medicineCategory %></h3>
                                                <h3 class="shopping-cart__product-details-subtitle">Qty: <%= singleCartItem.quantity %></h3>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="shopping-cart__product-price-container">
                                            <h1>Rs. <%= singleCartItem.price %></h1>
                                            <button 
                                                class="btn btn-danger shopping-cart__delete-btn"
                                                onclick="deleteItemFromCart( '<%= singleCartItem.medicineId._id %>' )"
                                                >
                                                <i class="fa-solid fa-trash-can"></i>
                                                <span>Remove</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <div class="shopping-cart__order-container">
                    <div class="shopping-cart__order-details">
                        <h3 class="shopping-cart__order-title">Order Summary</h3>
                        <div class="shopping-cart__order-details-row">
                            <p>Subtotal</p>
                            <p>
                                <i>Rs.</i><%= totalAmount %>
                            </p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p>Delivery Charges</p>
                            <p><i>Rs.</i>300</p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p>Items</p>
                            <p><%= totalCartItems %></p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p><b><i>Total</i></b></p>
                            <p><b>Rs.<%= (totalAmount + 300) %></b></p>
                        </div>
                    </div>

                    <div class="shopping-cart__order-actions">
                        <a href="/profile/cart/checkout" class="btn btn-dark w-100 fs-5 rounded rounded-5">
                            <b>Proceed to Checkout</b>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/scripts/cart/cart.js"></script>
<script src="/js/scripts/home/postlogin/search_medicine.js"></script>
<%- include( "../partials/footer/footer" ) -%>