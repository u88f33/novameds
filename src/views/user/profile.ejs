<%- include( "../partials/header/postlogin" ) -%>
<div class="banner">
        <div class="header-top__search-container" style="width: 1200px;">
            <div class="header-top__search-input-bar">
                <label for="searchBarInputLabel"><i class="fa-solid fa-magnifying-glass"></i></label>
                <input
                    type="text"
                    id="searchBarInputLabel"
                    placeholder="Search Medicines"
                    onclick="openSearchBox()" 
                    autocomplete="off"            
                    oninput="( this.value == '' )? window.location.replace( `/profile/?page=1` ) : searchMedicineByUser(this.value)"
                />
            </div>
        </div>
</div>

<%# Full Page search Box for searching Medicines %>

<div id="medicineListSearchContainer" class="medicines-list-search__container-background">

    <%# Display "X" icons for closing medicines search list  %>
    <div id="closeMedicinesListContainer" class="medicines-list-search__container-close">
        <i class="fa-solid fa-xmark"></i>
    </div>

    <%# Medicines List having search input on top and shows medicines list on typeing medicine name %>
    <div class="medicines-list-search__container">

        <%# HTML Form input for searching medicines  %>
        <div class="medicines-list-search__input-container">
            <label for="medicinesListInputLabel">
                <i class="fa-solid fa-magnifying-glass"></i>
            </label>
            <input
                type="text"
                id="medicinesListInputLabel"
                placeholder="Search Medicines"     
                oninput= "showMedicinesList(this.value)"
            />
        </div>

        <div class="medicines-list-display__container">
            <ul id="medicinesListDisplayOnSearch">

            </ul>
        </div>
    </div>


</div>

<%# Full page search Box for searching Medicines %>

<div class="container">
    <div class="row d-flex justify-content-center">

        </div>

        <div id="profilePageCardContainer" class="card-container">

            <%# Printing cards on a "http://localhost:5050/profile" %>
                <% if ( MedicinesRecordsFromDB ) { %>
                    <% MedicinesRecordsFromDB.forEach(singleMedicineRecord => { %>
                        <%#-- Card --%>
                        <div class="card">
                            <div class="card-header">
                                <img 
                                    src="/uploads/medicines/<%= singleMedicineRecord.medicineImage %>" 
                                    alt="Medicine">
                            </div>

                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <h3 class="card-title">
                                        <%= singleMedicineRecord.medicineName %>
                                    </h3>

                                    <span class="price">
                                        Rs. <%= singleMedicineRecord.medicinePrice %>
                                    </span>
                                </div>

                                <div class="card-info">
                                    <span class="category">
                                        <%= singleMedicineRecord.medicineCategory %>
                                    </span>
                                </div>

                                <a href="/profile/product/<%= singleMedicineRecord._id %>" class="add-to-cart-btn">
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            <%# End of forEach loop %>

        </div>
    </div>

    <!-- Pagination -->
    <div class="dashboard__section-pagination">

        <%# Move to Previous Page %>
        <% let currentPage = medicinesRecordsPaginationInfo.page %>
        <% if ( medicinesRecordsPaginationInfo.hasPrevPage ) { %>
            <a 
                href="/profile/?page=<%= currentPage - 1 %>" 
                class="pagination__btn"
            >
                &laquo;
            </a>
        <% } %>

        <div class="pagination__numbers">
            <% if ( medicinesRecordsPaginationInfo ) { %>
                <% if ( medicinesRecordsPaginationInfo.prevPage ) { %>
                    <a 
                        href="/profile/?page=<%= medicinesRecordsPaginationInfo.prevPage %>" 
                        class="pagination__btn"
                    >
                        <%= medicinesRecordsPaginationInfo.prevPage %>
                    </a>
                <% } %>

                <a 
                    href="/profile/?page=<%= medicinesRecordsPaginationInfo.page %>" 
                    class="pagination__btn"
                >
                    <%= medicinesRecordsPaginationInfo.page  %>
                </a>

                <% if ( medicinesRecordsPaginationInfo.nextPage ) { %>
                    <a 
                        href="/profile/?page=<%= medicinesRecordsPaginationInfo.nextPage %>" 
                        class="pagination__btn"
                    >
                        <%= medicinesRecordsPaginationInfo.nextPage %>
                    </a>
                <% } %>
        <% } %>
        </div>

        <%# Move to Next Page %>
        <% if ( medicinesRecordsPaginationInfo.hasNextPage ) { %>
            <a 
                href="/profile/?page=<%= currentPage + 1 %>" 
                class="pagination__btn"
            >
                &raquo;
            </a>
        <% } %>


    </div>

    

</div>


<script src="/js/scripts/home/postlogin/search_medicine.js"></script>
<%- include( "../partials/footer/footer" ) -%>