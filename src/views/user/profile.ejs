<%- include( "../partials/header/postlogin" ) -%>
<%- include( "../partials/banner/banner" ) -%>
<%- include( "../partials/banner/fullPageSearchList" ) -%>

<div class="container">
    <div class="row d-flex justify-content-center">

        </div>

        <div id="profilePageCardContainer" class="card-container">

            <%# Printing cards on a "http://localhost:5050/profile" %>
                <% if ( MedicinesRecordsFromDB ) { %>
                    <% MedicinesRecordsFromDB.forEach(singleMedicineRecord => { %>
                        <%#-- Card --%>
                        <div class="card">
                            <div class="card-header">
                                <img 
                                    src="/uploads/medicines/<%= singleMedicineRecord.medicineImage %>" 
                                    alt="Medicine">
                            </div>

                            <div class="card-body">
                                <div class="d-flex flex-column">
                                    <h3 class="card-title">
                                        <%= singleMedicineRecord.medicineName %>
                                    </h3>

                                <div class="card-subtitle">
                                    <div class="card-subtitle-col">
                                        <span class="price">
                                            Rs. <%= singleMedicineRecord.medicinePrice %>
                                        </span>
                                    </div>
                                    <div class="card-subtitle-col">
                                        <span class="stock">
                                            <% if (Number(singleMedicineRecord.medicineStock)  == 0) { %>
                                                <i class="fa-solid fa-circle-exclamation"></i>
                                                Out of stock
                                            <% } %>
                                        </span>
                                    </div>
                                </div>
                                </div>

                                <div class="card-info">
                                    <span class="category">
                                        <%= singleMedicineRecord.medicineCategory %>
                                    </span>
                                </div>

                                <a href="/profile/product/<%= singleMedicineRecord._id %>" class="add-to-cart-btn">
                                    Add to Cart
                                </a>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            <%# End of forEach loop %>

        </div>
    </div>

    <!-- Pagination -->
    <div class="dashboard__section-pagination">

        <%# Move to Previous Page %>
        <% let currentPage = medicinesRecordsPaginationInfo.page %>
        <% if ( medicinesRecordsPaginationInfo.hasPrevPage ) { %>
            <a 
                href="/profile/?page=<%= currentPage - 1 %>" 
                class="pagination__btn"
            >
                &laquo;
            </a>
        <% } %>

        <div class="pagination__numbers">
            <% if ( medicinesRecordsPaginationInfo ) { %>
                <% if ( medicinesRecordsPaginationInfo.prevPage ) { %>
                    <a 
                        href="/profile/?page=<%= medicinesRecordsPaginationInfo.prevPage %>" 
                        class="pagination__btn"
                    >
                        <%= medicinesRecordsPaginationInfo.prevPage %>
                    </a>
                <% } %>

                <a 
                    href="/profile/?page=<%= medicinesRecordsPaginationInfo.page %>" 
                    class="pagination__btn"
                >
                    <%= medicinesRecordsPaginationInfo.page  %>
                </a>

                <% if ( medicinesRecordsPaginationInfo.nextPage ) { %>
                    <a 
                        href="/profile/?page=<%= medicinesRecordsPaginationInfo.nextPage %>" 
                        class="pagination__btn"
                    >
                        <%= medicinesRecordsPaginationInfo.nextPage %>
                    </a>
                <% } %>
        <% } %>
        </div>

        <%# Move to Next Page %>
        <% if ( medicinesRecordsPaginationInfo.hasNextPage ) { %>
            <a 
                href="/profile/?page=<%= currentPage + 1 %>" 
                class="pagination__btn"
            >
                &raquo;
            </a>
        <% } %>


    </div>

    

</div>


<script src="/js/scripts/home/postlogin/search_medicine.js"></script>
<%- include( "../partials/footer/footer" ) -%>