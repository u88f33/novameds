<%- include( "../partials/header/postlogin" ) -%>

<div class="container">
    <div class="row">

        <div class="order-confirmation">
            <div class="order-confirmation__heading-container">
                <h1 class="order-confirmation__heading">Place an Order</h1>
            </div>

            <div class="order-confirmation__body-container">
                <div class="order-confirmation__info">
                    <h4>Payment Method</h4>
                    <hr />
                    <form action="/profile/cart/checkout" method="POST">
                        <div>
                            <label for="cod_opt">
                                <input
                                    id="cod_opt" 
                                    type="radio" 
                                    name="payment_method"
                                    value="cod"
                                    checked="checked" /> Cash On Delivery
                            </label>
                        </div>
                        <div>
                            <label for="easypaisa_opt">
                                <input 
                                    id="easypaisa_opt" 
                                    type="radio"
                                    name="payment_method" 
                                    value="easypaisa" /> Easypaisa
                            </label>
                        </div>
                    </form>

                    
                    <div class="payment-box__container">
                        
                        <!-- COD -->
                        <div id="cod" class="payment-box__info">
                            <p>No details required. Pay on delivery.</p>
                        </div>

                        <!-- Easypaisa -->
                        <div id="easypaisa" class="payment-box__info">
                            <div class="payment-box__image-container w-100">
                                <img 
                                    src="/assets/images/easypaisa.jpg"
                                    class="payment-box__image mb-4"
                                    style="width: 300px; border-radius: 20px;"
                                />
                            </div>
                            <div class="payment-box__admin-account-info">
                                    <h3>Easypaisa account info</h3>
                                    <p>Send your payments to</p>
                                    <p><b>Account name: </b>Muhammad Umar Farooq</p>
                                    <p><b>Phone number: </b>03185043662</p>
                                    <br /><br />
                                    <p>
                                        After completion of payment, your payment status will be
                                        updated by admin. 
                                    </p>
                            </div>
                        </div>

                    </div>

                    <div class="shipping-form">
                        
                        <!-- Permanent Address -->
                        <h4 class="mt-5">Permanent Address</h4>
                        <hr />
                        <!-- Permanent Address Section -->
                        <div class="shipping-form__section">

                            <!-- Top Block -->
                            <div class="shipping-form__group">

                                <!-- Row 1 -->
                                <div class="shipping-form__row">
                                    <div class="shipping-form__field">
                                        <label for="perm_address">Permanent Address</label>
                                        <input type="text" id="perm_address" class="shipping-form__input" />
                                    </div>

                                    <div class="shipping-form__field">
                                        <label for="perm_city">City</label>
                                        <input type="text" id="perm_city" class="shipping-form__input" />
                                    </div>
                                </div>

                                <!-- Row 2 -->
                                <div class="shipping-form__row">
                                    <div class="shipping-form__field">
                                        <label for="perm_state">State</label>
                                        <input type="text" id="perm_state" class="shipping-form__input" />
                                    </div>

                                    <div class="shipping-form__field">
                                        <label for="perm_postal">Postal Code</label>
                                        <input type="text" id="perm_postal" class="shipping-form__input" />
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Shipping Address -->
                        <h4 class="mt-5">Shipping Address</h4>
                        <hr />
                        <!-- Shipping Address Section -->
                        <div class="shipping-form__section">

                            <!-- Bottom Block -->
                            <div class="shipping-form__group">

                                <!-- Row 1 -->
                                <div class="shipping-form__row">
                                    <div class="shipping-form__field">
                                        <label for="ship_address">Shipping Address</label>
                                        <input type="text" id="ship_address" class="shipping-form__input" />
                                    </div>

                                    <div class="shipping-form__field">
                                        <label for="ship_city">City</label>
                                        <input type="text" id="ship_city" class="shipping-form__input" />
                                    </div>
                                </div>

                                <!-- Row 2 -->
                                <div class="shipping-form__row">
                                    <div class="shipping-form__field">
                                        <label for="ship_state">State</label>
                                        <input type="text" id="ship_state" class="shipping-form__input" />
                                    </div>

                                    <div class="shipping-form__field">
                                        <label for="ship_postal">Postal Code</label>
                                        <input type="text" id="ship_postal" class="shipping-form__input" />
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Checkbox -->
                        <div class="shipping-form__checkbox">
                            <label for="same_address">
                                <input type="checkbox" id="same_address" />
                                Same as Permanent Address
                            </label>
                        </div>

                    </div>
                    
                </div>

                <div class="shopping-cart__order-container">
                    <div class="shopping-cart__order-details">
                        <h3 class="shopping-cart__order-title">Order Summary</h3>
                        <div class="shopping-cart__order-details-row">
                            <p>Subtotal</p>
                            <p>
                                <i>Rs.</i><%= totalAmount %>
                            </p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p>Delivery Charges</p>
                            <p><i>Rs.</i>300</p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p>Items</p>
                            <p><%= totalCartItems %></p>
                        </div>
                        <div class="shopping-cart__order-details-row">
                            <p><b><i>Total</i></b></p>
                            <p><b>Rs.<%= (totalAmount + 300) %></b></p>
                        </div>
                    </div>

                    <div class="shopping-cart__order-actions">
                        <a href="/profile/cart/checkout" class="btn btn-dark w-100 fs-5 rounded rounded-5">
                            <b>Confirm Order</b>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/js/scripts/orders/payments.js"></script>
<script src="/js/scripts/cart/cart.js"></script>
<script src="/js/scripts/home/postlogin/search_medicine.js"></script>
<%- include( "../partials/footer/footer" ) -%>